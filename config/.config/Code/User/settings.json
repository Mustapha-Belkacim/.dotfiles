{
  "update.mode": "none",
  "workbench.colorTheme": "Catppuccin Macchiato",
  "github.copilot.nextEditSuggestions.enabled": true,
  "editor.fontSize": 14,
  // "editor.fontFamily": "Hack Nerd Font Mono",
  "editor.fontFamily": "Fira Code",
  "editor.fontLigatures": true,
  "editor.formatOnPaste": true,
  "editor.insertSpaces": true,
  "editor.renderWhitespace": "trailing",
  "editor.rulers": [100],
  "extensions.experimental.affinity": {
      "asvetliakov.vscode-neovim": 1
  },
  "workbench.tree.indent": 24,
  "workbench.tree.renderIndentGuides": "always",
  "editor.lineNumbers": "relative",
  "editor.minimap.enabled": false,
  "editor.cursorSurroundingLines": 3,
  "editor.linkedEditing": true,
  "javascript.updateImportsOnFileMove.enabled": "always",
  "zenMode.hideLineNumbers": false,
  "window.zoomLevel": 0.4,
  "breadcrumbs.enabled": true,

  "vim.leader": "<Space>",
  "vim.hlsearch": true,
  "vim.useSystemClipboard": true,
  "vim.incsearch": true,
  "vim.highlightedyank.enable": true,
  "vim.normalModeKeyBindingsNonRecursive": [

    { "before": ["g", "h"], "commands": ["editor.action.showDefinitionPreviewHover"] },
    { "before": ["<CR>"], "commands": ["editor.action.insertLineAfter", "cursorUp"] },
    { "before": ["<leader>", "<CR>"], "commands": ["editor.action.insertLineBefore", "cursorDown"] },
    { "before": ["leader", "a"], "commands": ["editor.action.selectAll"] },
    { "before": ["<leader>", "e"], "commands": ["workbench.action.toggleSidebarVisibility"] },

    { "before": ["<leader>", "t"], "commands": ["workbench.action.tasks.showTasks"] },


    // Replace / find / copy-path / other common actions
    { "before": ["<leader>", "p", "a"], "commands": ["copyFilePath"] },
    { "before": ["<leader>", "p", "n"], "commands": ["extension.copyPathWithLine"] }, // not working

    // Find
    { "before": ["<leader>", "<leader>"], "commands": ["workbench.action.quickOpen"] },
    { "before": ["<leader>", "f", "f"], "commands": ["workbench.action.quickOpen"] },
    { "before": ["<leader>", "f", "b"], "commands": ["workbench.action.showAllEditors"] },
    { "before": ["<leader>", "f", "r"], "commands": ["workbench.action.openRecent"] },
    { "before": ["<leader>", "f", "n"], "commands": ["workbench.action.files.newUntitledFile"] },

    // Buffers
    { "before": ["<Tab>"], "commands": [":bnext"] },
    { "before": ["<S-Tab>"], "commands": [":bprevious"] },
    { "before": ["<leader>", "b", "d"], "commands": ["workbench.action.closeActiveEditor"] },
    { "before": ["<leader>", "b", "a"], "commands": ["workbench.action.showAllEditors"] },
    { "before": ["<leader>", "b", "Q"], "commands": ["workbench.action.closeAllEditors"] },

    // Code
    { "before": ["<leader>", "c", "q"], "commands": ["editor.action.quickFix"] },
    { "before": ["<leader>", "c", "r"], "commands": ["editor.action.rename"] },
    { "before": ["<leader>", "c", "f"], "commands": ["editor.action.formatDocument"] },
    { "before": ["<leader>", "c", "i"], "commands": ["editor.action.showHover"] },

    // Debug
    { "before": ["<leader>", "d", "b"], "commands": ["editor.debug.action.toggleBreakpoint"] },

    // Diagnostics
    { "before": ["<leader>", "x", "d"], "commands": ["workbench.action.problems.focus"] },
    { "before": ["<leader>", "x", "q"], "commands": ["editor.action.quickFix"] },
    { "before": ["[", "d"], "commands": ["editor.action.marker.prev"] },
    { "before": ["]", "d"], "commands": ["editor.action.marker.next"] },

    // Git
    { "before": ["<leader>", "g", "g"], "commands": ["workbench.view.scm"] },
    { "before": ["<leader>", "g", "b"], "commands": ["git.openChange"] },

    // Search
    { "before": ["<leader>", "/"], "commands": ["workbench.action.findInFiles"] },
    { "before": ["<leader>", "s", "s"], "commands": ["workbench.action.findInFiles"] },
    { "before": ["<leader>", "s", "r"], "commands": ["editor.action.startFindReplaceAction"] },
    { "before": ["<leader>", "s", "k"], "commands": ["workbench.action.showCommands"] },
    { "before": ["<leader>", ":"], "commands": ["workbench.action.showCommands"] },

    // Terminal / toggles
    { "before": ["<leader>", "t", "t"], "commands": ["workbench.action.terminal.toggleTerminal"] },

    // Windows
    { "before": ["<leader>", "w", "v"], "commands": ["workbench.action.splitEditorRight"] },
    { "before": ["<leader>", "w", "s"], "commands": ["workbench.action.splitEditorDown"] },
    { "before": ["<leader>", "w", "h"], "commands": ["workbench.action.focusLeftGroup"] },
    { "before": ["<leader>", "w", "j"], "commands": ["workbench.action.focusBelowGroup"] },
    { "before": ["<leader>", "w", "k"], "commands": ["workbench.action.focusAboveGroup"] },
    { "before": ["<leader>", "w", "l"], "commands": ["workbench.action.focusRightGroup"] },
    { "before": ["<leader>", "w", "d"], "commands": ["workbench.action.closeGroup"] },
    { "before": ["<leader>", "w", "o"], "commands": ["workbench.action.closeOtherGroups"] },
    { "before": ["leader", "\\"], "commands": [":vsplit"] },
    { "before": ["leader", "-"], "commands": [":split"] },
    { "before": ["leader", "h"], "commands": ["workbench.action.focusLeftGroup"] },
    { "before": ["leader", "j"], "commands": ["workbench.action.focusBelowGroup"] },
    { "before": ["leader", "k"], "commands": ["workbench.action.focusAboveGroup"] },
    { "before": ["leader", "l"], "commands": ["workbench.action.focusRightGroup"] },

  ],
  "vim.visualModeKeyBindings": [
    // Stay in visual mode while indenting
    { "before": ["<"], "commands": ["editor.action.outdentLines"] },
    { "before": [">"], "commands": ["editor.action.indentLines"] },
    // Move selected lines while staying in visual mode
    { "before": ["J"], "commands": ["editor.action.moveLinesDownAction"] },
    { "before": ["K"], "commands": ["editor.action.moveLinesUpAction"] },
    { "before": ["<leader>", "c"], "commands": ["editor.action.commentLine"] }
  ],
    "[typescriptreact]": {
      "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[typescript]": {
      "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[jsonc]": {
      "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "files.autoSave": "afterDelay",
  "files.trimTrailingWhitespace": true,
  "git.blame.statusBarItem.enabled": true,
  "git.blame.editorDecoration.enabled": false,
  "git.autofetch": true,
  "git.confirmSync": false,
  "diffEditor.ignoreTrimWhitespace": true,
  "diffEditor.experimental.showMoves": true,
  "window.autoDetectColorScheme": true,
  "workbench.preferredDarkColorTheme": "Catppuccin Macchiato",
  "workbench.preferredLightColorTheme": "Catppuccin Latte",
  "containers.containerClient": "com.microsoft.visualstudio.containers.docker",
  "containers.orchestratorClient": "com.microsoft.visualstudio.orchestrators.dockercompose",
  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilot:gpt-4.1",
  "gitlens.currentLine.enabled": false,
  "gitlens.views.branches.files.layout": "tree",
  "atlascode.rovodev.showEntitlementNotifications": false,
  "atlascode.bitbucket.enabled": false,
  "atlascode.jira.startWorkBranchTemplate.customTemplate": "{{{prefix}}}{{{issueKey}}}_{{{summary}}}",
  "atlascode.rovodev.enabled": false,
  "docker.extension.enableComposeLanguageServer": false,
  "chat.fontSize": 14,
  "chat.editor.fontSize": 14,
  "chat.tools.terminal.autoApprove": {
    "docker compose": true,
    "bat": true,
    "uv": true
  },
  "chat.mcp.gallery.enabled": true,
  "chat.tools.urls.autoApprove": {
    "https://pypi.org/pypi/langgraph/json": {
      "approveRequest": true,
      "approveResponse": false
    }
  },
  "chat.viewSessions.orientation": "stacked",
  "gitlab.duoCodeSuggestions.openTabsContext": false,
  "gitlab.duoCodeSuggestions.enabled": false,
}
